@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <div class="hero-content">
        <h1>Make Every Day<br>a Fashion Show</h1>
        <p>Experience the intersection of quiet luxury and bold modernity.</p>
        <a asp-controller="Products" asp-action="Index" class="btn-primary">Explore Collection</a>
    </div>
</section>

<section class="section">
    <h2 class="section-title">Wardrobe</h2>
    <div class="product-grid">
        @foreach (var product in Model.FeaturedProducts)
        {
            <div class="product-card">
                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id">
                    <img src="@product.ImageUrl" alt="@product.Name" />
                    <div class="card-info">
                        <h3>@product.Name</h3>
                        <p>₱@product.Price.ToString("N2")</p>
                    </div>
                </a>
            </div>
        }
    </div>
</section>