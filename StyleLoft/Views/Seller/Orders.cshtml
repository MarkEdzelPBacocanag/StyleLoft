@model List<StyleLoft.Controllers.SellerController.SellerOrderViewModel>
@{
    ViewData["Title"] = "Seller Orders";
}

@if (TempData["Success"] != null)
{
    <div id="temp-toast" class="toast-notification" style="position: fixed; top: 20px; right: 20px; background: #28a745; color: white; padding: 1rem 1.5rem; border-radius: 8px; z-index: 1000; box-shadow: 0 4px 16px rgba(0,0,0,0.2); display: flex; align-items: center; gap: 0.75rem; opacity: 0; transform: translateX(100px);">
        <span style="font-size: 1.25rem;">✅</span>
        <span>@TempData["Success"]</span>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-dismiss temp toast with animation
            const tempToast = document.getElementById('temp-toast');
            if (tempToast) {
                // Animate in
                tempToast.style.transition = 'opacity 0.3s ease-out, transform 0.3s ease-out';
                setTimeout(() => {
                    tempToast.style.opacity = '1';
                    tempToast.style.transform = 'translateX(0)';
                }, 50);
                
                // Animate out
                setTimeout(() => {
                    tempToast.style.opacity = '0';
                    tempToast.style.transform = 'translateX(100px)';
                    setTimeout(() => tempToast.remove(), 300);
                }, 3000);
            }

            // Status dropdown functionality
            document.querySelectorAll('.status-dropdown-trigger').forEach(trigger => {
                trigger.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const dropdown = this.nextElementSibling;
                    
                    // Close all other dropdowns
                    document.querySelectorAll('.status-dropdown-menu').forEach(menu => {
                        if (menu !== dropdown) menu.style.display = 'none';
                    });
                    
                    dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
                });
            });

            // Close dropdowns when clicking outside
            document.addEventListener('click', function() {
                document.querySelectorAll('.status-dropdown-menu').forEach(menu => {
                    menu.style.display = 'none';
                });
            });

            // Handle status change
            document.querySelectorAll('.status-option').forEach(option => {
                option.addEventListener('click', async function(e) {
                    e.preventDefault();
                    const orderId = this.dataset.orderId;
                    const newStatus = this.dataset.status;
                    const dropdownMenu = this.closest('.status-dropdown-menu');
                    const trigger = dropdownMenu.previousElementSibling;
                    const orderCard = trigger.closest('.order-card');
                    
                    try {
                        const response = await fetch('/Seller/UpdateOrderStatusAjax', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                            },
                            body: `id=${encodeURIComponent(orderId)}&status=${encodeURIComponent(newStatus)}`
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            // Update the status display
                            trigger.textContent = result.newStatus;
                            
                            // Update badge colors
                            trigger.className = 'status-dropdown-trigger';
                            if (result.newStatus === 'Delivered') {
                                trigger.style.background = '#28a745';
                                trigger.style.color = 'white';
                            } else if (result.newStatus === 'Shipped') {
                                trigger.style.background = '#ffc107';
                                trigger.style.color = '#333';
                            } else {
                                trigger.style.background = '#6c757d';
                                trigger.style.color = 'white';
                            }
                            
                            dropdownMenu.style.display = 'none';
                            
                            // Show toast notification
                            showToast('Status updated successfully!', 'success');
                        } else {
                            showToast('Failed to update status: ' + result.message, 'error');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        showToast('An error occurred while updating the status.', 'error');
                    }
                });
            });

            function showToast(message, type = 'success') {
                // Remove existing toast if any
                const existingToast = document.querySelector('.toast-notification');
                if (existingToast) existingToast.remove();

                const toast = document.createElement('div');
                toast.className = 'toast-notification';
                
                const bgColor = type === 'success' ? '#28a745' : '#dc3545';
                const icon = type === 'success' ? '✅' : '❌';
                
                toast.style.cssText = `
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    background: ${bgColor};
                    color: white;
                    padding: 1rem 1.5rem;
                    border-radius: 8px;
                    z-index: 1000;
                    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                    animation: slideIn 0.3s ease-out;
                `;
                
                toast.innerHTML = `
                    <span style="font-size: 1.25rem;">${icon}</span>
                    <span>${message}</span>
                `;
                
                document.body.appendChild(toast);
                
                setTimeout(() => {
                    toast.style.transition = 'opacity 0.3s ease-out, transform 0.3s ease-out';
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(100px)';
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            }
        });
    </script>
}

<style>
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateX(100px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>

<div class="container" style="max-width: 1400px; margin: 0 auto; padding: 2rem;">
    <div style="margin-bottom: 2rem;">
        <a asp-controller="Seller" asp-action="Atelier" style="color: #d4af37; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
            &larr; Back to Atelier
        </a>
    </div>

    <div class="orders-page-header" style="margin-bottom: 2rem;">
        <h1>Seller Orders</h1>
        <p>Manage and update your order statuses.</p>
    </div>

    @if (Model.Any())
    {
        <div class="orders-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem;">
            @foreach (var viewModel in Model)
            {
                var order = viewModel.Order;
                <div class="order-card" style="background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: transform 0.2s ease, box-shadow 0.2s ease;">
                    <div class="order-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <div class="order-id">
                            <span class="label" style="font-size: 0.8rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px;">Order Number</span>
                            <span class="value" style="font-weight: 700; display: block; font-size: 1.1rem; margin-top: 0.25rem;">@order.OrderNumber</span>
                        </div>
                        <div class="order-status-wrapper" style="position: relative;">
                            <button class="status-dropdown-trigger" style="padding: 0.5rem 1rem; border-radius: 24px; font-size: 0.8rem; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s ease; @(order.Status == "Delivered" ? "background: #28a745; color: white;" : order.Status == "Shipped" ? "background: #ffc107; color: #333;" : "background: #6c757d; color: white;")">
                                @order.Status
                            </button>
                            <div class="status-dropdown-menu" style="display: none; position: absolute; top: 100%; right: 0; margin-top: 0.75rem; background: white; border-radius: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); z-index: 100; min-width: 160px; overflow: hidden;">
                                <a href="#" class="status-option" data-order-id="@order.Id" data-status="Pending" style="display: block; padding: 0.875rem 1.25rem; text-decoration: none; color: #333; cursor: pointer; transition: background 0.15s ease;">Pending</a>
                                <a href="#" class="status-option" data-order-id="@order.Id" data-status="Processing" style="display: block; padding: 0.875rem 1.25rem; text-decoration: none; color: #333; cursor: pointer; transition: background 0.15s ease;">Processing</a>
                                <a href="#" class="status-option" data-order-id="@order.Id" data-status="Shipped" style="display: block; padding: 0.875rem 1.25rem; text-decoration: none; color: #333; cursor: pointer; transition: background 0.15s ease;">Shipped</a>
                                <a href="#" class="status-option" data-order-id="@order.Id" data-status="Delivered" style="display: block; padding: 0.875rem 1.25rem; text-decoration: none; color: #333; cursor: pointer; transition: background 0.15s ease;">Delivered</a>
                            </div>
                        </div>
                    </div>
                    
                    <div class="order-body" style="margin-bottom: 1rem;">
                        <div class="order-details" style="display: flex; flex-direction: column; gap: 0.5rem;">
                            <p style="margin: 0; font-size: 0.95rem; color: #555;"><strong>Date:</strong> @order.OrderDate.ToString("MMM dd, yyyy")</p>
                            <p style="margin: 0; font-size: 0.95rem; color: #555;"><strong>Items:</strong> @viewModel.SellerOrderItems.Count</p>
                            <p style="margin: 0; font-size: 0.95rem; color: #555;"><strong>Customer:</strong> @(order.User != null ? $"{order.User.FirstName} {order.User.LastName}" : "Unknown")</p>
                        </div>
                        
                        <div style="margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
                            @foreach (var item in viewModel.SellerOrderItems)
                            {
                                if (item.Product != null)
                                {
                                    <img src="@item.Product.ImageUrl" alt="@item.Product.Name" 
                                         style="width: 60px; height: 60px; object-fit: cover; border-radius: 6px; border: 2px solid #f0f0f0;" />
                                }
                            }
                        </div>
                    </div>
                    
                    <div class="order-footer" style="padding-top: 1rem; border-top: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center;">
                        <span style="color: #888; font-size: 0.875rem;">Your Total</span>
                        <span style="font-size: 1.5rem; font-weight: 700; color: #d4af37;">₱@viewModel.SellerTotal.ToString("N2")</span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="text-align: center; padding: 4rem 2rem; background: #f8f9fa; border-radius: 16px;">
            <div style="font-size: 4rem; margin-bottom: 1rem;">📦</div>
            <h2 style="margin-bottom: 0.5rem;">No orders yet</h2>
            <p style="color: #666;">You haven't received any orders yet.</p>
        </div>
    }
</div>
