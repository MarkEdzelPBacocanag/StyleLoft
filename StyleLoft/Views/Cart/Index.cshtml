@model CartViewModel
@{
    ViewData["Title"] = "Shopping Bag";
}

<h1>Shopping Bag</h1>
<div class="cart-layout">
    <div class="cart-items">
        @if (Model.Items.Any())
        {
            @foreach (var item in Model.Items)
            {
                <div class="cart-item">
                    <img src="@item.ImageUrl" alt="@item.ProductName" />
                    <div class="item-details">
                        <h3>@item.ProductName</h3>
                        <p>@item.Material</p>
                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="qty-form">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)">-</button>
                            <span>@item.Quantity</span>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)">+</button>
                        </form>
                    </div>
                    <div class="item-price">
                        <p>₱@item.Total.ToString("N2")</p>
                        <form asp-controller="Cart" asp-action="Remove" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="remove-btn">Remove</button>
                        </form>
                    </div>
                </div>
            }
        }
        else
        {
            <p>Your bag is empty.</p>
        }

        <div style="margin-bottom: 1rem;">
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline" style="padding: 0.75rem 1.5rem; border: 1px solid #d4af37; color: #d4af37; text-decoration: none; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.5rem;">
                + Add Another Product
            </a>
        </div>
    </div>

    <div class="order-summary">
        <h2>Order Summary</h2>
        
        <div style="margin-bottom: 1.5rem; padding: 1rem; background: #f8f6f3; border-radius: 4px;">
            <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem; color: #222;">Shipping Address</h3>
            @{
                var hasAddress = !string.IsNullOrEmpty(Model.StreetAddress) || 
                                 !string.IsNullOrEmpty(Model.City) || 
                                 !string.IsNullOrEmpty(Model.StateProvince) || 
                                 !string.IsNullOrEmpty(Model.ZipPostalCode) || 
                                 !string.IsNullOrEmpty(Model.Country);
            }
            @if (hasAddress)
            {
                <p style="margin: 0; line-height: 1.6; color: #555;">
                    @if (!string.IsNullOrEmpty(Model.StreetAddress))
                    {
                        @Model.StreetAddress<br />
                    }
                    @{
                        var cityPart = "";
                        if (!string.IsNullOrEmpty(Model.City))
                        {
                            cityPart = Model.City;
                        }
                        if (!string.IsNullOrEmpty(Model.City) && !string.IsNullOrEmpty(Model.StateProvince))
                        {
                            cityPart += ", ";
                        }
                        if (!string.IsNullOrEmpty(Model.StateProvince))
                        {
                            cityPart += Model.StateProvince;
                        }
                        if (!string.IsNullOrEmpty(cityPart) && !string.IsNullOrEmpty(Model.ZipPostalCode))
                        {
                            cityPart += " " + Model.ZipPostalCode;
                        }
                    }
                    @if (!string.IsNullOrEmpty(cityPart))
                    {
                        @cityPart<br />
                    }
                    @if (!string.IsNullOrEmpty(Model.Country))
                    {
                        @Model.Country
                    }
                </p>
            }
            else
            {
                <p style="margin: 0; color: #888; font-style: italic;">No shipping address provided.</p>
            }
        </div>

        <div class="summary-row"><span>Subtotal</span><span>₱@Model.Subtotal.ToString("N2")</span></div>
        <div class="summary-row"><span>Shipping</span><span>@(Model.Shipping == 0 ? "Complimentary" : "₱" + Model.Shipping.ToString("N2"))</span></div>
        <div class="summary-total"><span>Total</span><span>₱@Model.Total.ToString("N2")</span></div>

        <!-- Form posts the whole CartViewModel to OrderController.Checkout -->
        <form asp-controller="Orders" asp-action="Checkout" method="post">
            <input type="hidden" name="StreetAddress" value="@Model.StreetAddress" />
            <input type="hidden" name="City" value="@Model.City" />
            <input type="hidden" name="StateProvince" value="@Model.StateProvince" />
            <input type="hidden" name="ZipPostalCode" value="@Model.ZipPostalCode" />
            <input type="hidden" name="Country" value="@Model.Country" />
            @if (Model.Items.Any())
            {
                <button type="submit" class="btn-gold btn-block">Proceed to Checkout</button>
            }
            else
            {
                <button type="submit" class="btn-gold btn-block" disabled style="opacity: 0.5; cursor: not-allowed;">Proceed to Checkout</button>
            }
        </form>
    </div>
</div>

@section Scripts {
    <script>
        async function autocompleteAddress(input, cityInput, provinceInput, zipInput, countryInput) {
            let timeoutId;
            const wrapper = document.createElement('div');
            wrapper.style.position = 'relative';
            input.parentNode.insertBefore(wrapper, input.nextSibling);
            wrapper.appendChild(input);
            
            let dropdown = document.createElement('div');
            dropdown.style.position = 'absolute';
            dropdown.style.top = '100%';
            dropdown.style.left = '0';
            dropdown.style.right = '0';
            dropdown.style.background = '#fff';
            dropdown.style.border = '1px solid #ddd';
            dropdown.style.borderRadius = '4px';
            dropdown.style.maxHeight = '200px';
            dropdown.style.overflowY = 'auto';
            dropdown.style.zIndex = '1000';
            dropdown.style.display = 'none';
            wrapper.appendChild(dropdown);

            input.addEventListener('input', function() {
                clearTimeout(timeoutId);
                const query = this.value.trim();
                if (query.length < 3) {
                    dropdown.style.display = 'none';
                    return;
                }

                timeoutId = setTimeout(async () => {
                    try {
                        const response = await fetch(
                            `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query + ', Philippines')}&countrycodes=PH&limit=5`
                        );
                        const data = await response.json();
                        
                        dropdown.innerHTML = '';
                        if (data.length === 0) {
                            dropdown.style.display = 'none';
                            return;
                        }

                        data.forEach(place => {
                            const item = document.createElement('div');
                            item.style.padding = '0.8rem';
                            item.style.cursor = 'pointer';
                            item.style.borderBottom = '1px solid #eee';
                            item.textContent = place.display_name;
                            item.addEventListener('click', function() {
                                input.value = place.display_name.split(', Philippines')[0];
                                
                                let city = '';
                                let province = '';
                                let zip = '';
                                
                                const parts = place.display_name.split(', ');
                                for (let i = 0; i < parts.length; i++) {
                                    if (parts[i].toLowerCase().includes('city')) {
                                        city = parts[i];
                                    }
                                    if (parts[i].toLowerCase().includes('province') || parts[i].toLowerCase().includes('region')) {
                                        province = parts[i];
                                    }
                                }
                                
                                cityInput.value = city;
                                provinceInput.value = province;
                                zipInput.value = place.address?.postcode || '';
                                countryInput.value = 'Philippines';
                                
                                dropdown.style.display = 'none';
                            });
                            dropdown.appendChild(item);
                        });

                        dropdown.style.display = 'block';
                    } catch (error) {
                        console.error('Autocomplete error:', error);
                    }
                }, 300);
            });

            document.addEventListener('click', function(e) {
                if (!wrapper.contains(e.target)) {
                    dropdown.style.display = 'none';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            const streetInput = document.querySelector('input[name="StreetAddress"]');
            const cityInput = document.querySelector('input[name="City"]');
            const provinceInput = document.querySelector('input[name="StateProvince"]');
            const zipInput = document.querySelector('input[name="ZipPostalCode"]');
            const countryInput = document.querySelector('input[name="Country"]');
            
            if (streetInput) {
                autocompleteAddress(streetInput, cityInput, provinceInput, zipInput, countryInput);
            }
        });
    </script>
}
